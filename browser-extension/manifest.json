{
  "manifest_version": 3,
  "name": "Giftly Save",
  "version": "0.1.0",
  "description": "Save Amazon products to your Giftly wishlist.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.de/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.com.au/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Giftly"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.co.jp/*",
        "https://www.amazon.com.au/*"
      ],
      "js": ["content/amazon.js"],
      "run_at": "document_idle"
    }
  ]
}
